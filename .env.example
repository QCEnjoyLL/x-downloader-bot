# Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_bot_token_here

# 服务端口（可选，默认 3000）
PORT=3000

# 轮询模式：无需公网 HTTPS，机器人主动拉取消息（推荐）
POLLING=true

# 上传成功后删除本地视频（默认 true）
# 设为 false 则保留所有下载的视频在 ./downloads 目录
CLEANUP_VIDEOS=true

# 多链接并发下载上限（默认 3）。注意：每个下载会把整文件读进内存，
# 2GB 模式下并发太高可能吃满内存，按机器内存调整
DOWNLOAD_CONCURRENCY=3

# 直播回放(broadcasts)第三方解析兜底（可选）。yt-dlp 失败时启用。
# 需是一个返回内容里含直链 mp4 的接口，用 {url} 占位待解析的 X 链接，例如：
# BROADCAST_RESOLVER_URL=https://your-resolver.example/api?u={url}
BROADCAST_RESOLVER_URL=

# 本地 Bot API（可选，突破 50MB 上传限制）
# 去 https://my.telegram.org/apps 创建应用获取
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# TELEGRAM_API_URL=http://api:8081   # docker-compose 自动设置
